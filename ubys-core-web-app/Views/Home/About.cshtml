@{
    ViewData["Title"] = "Hakkımızda";
}

<!-- Page Header -->
<section class="page-header">
    <div class="page-header-bg">
        <div class="header-orb header-orb-1"></div>
        <div class="header-orb header-orb-2"></div>
    </div>
    <div class="section-container page-header-content">
        <span class="section-badge animate-on-scroll">🏛️ Hakkımızda</span>
        <h1 class="section-title animate-on-scroll" style="font-size: clamp(2.5rem, 5vw, 3.5rem);">
            Eğitim Teknolojilerinde <span class="gradient-text">Güvenilir Çözüm Ortağı</span>
        </h1>
        <p class="section-description animate-on-scroll">
            15 yılı aşkın tecrübemiz ile Türkiye'nin en büyük üniversite bilgi yönetim sistemi ekosistemini oluşturuyoruz.
        </p>
    </div>
</section>

<!-- About Content -->
<section class="section" style="padding-top: 40px;">
    <div class="section-container">
        <div class="about-content-grid">
            <div class="about-image-wrapper animate-on-scroll">
                <div class="about-image-box">
                    <div class="placeholder-content">
                        <div class="placeholder-icon">🚀</div>
                        <div class="placeholder-text">İnovasyon & Teknoloji</div>
                    </div>
                </div>
                <div class="about-image-decor"></div>
            </div>
            <div class="about-text animate-on-scroll">
                <h2>Misyonumuz</h2>
                <p>
                    UBYS olarak, eğitim kurumlarının dijital dönüşüm yolculuğunda en güvenilir çözüm ortağı olmayı
                    hedefliyoruz. Yenilikçi teknolojiler ve kullanıcı odaklı tasarım anlayışımız ile üniversitelerin
                    yönetim süreçlerini basitleştiriyoruz.
                </p>
                <p>
                    2011 yılında kurulan şirketimiz, bugün 150'den fazla eğitim kurumuna hizmet vererek
                    Türkiye'nin en kapsamlı üniversite bilgi yönetim platformunu sunmaktadır.
                </p>
                <div style="margin-top: 24px;">
                    <a asp-controller="Home" asp-action="Services" class="btn-primary-custom">
                        Hizmetlerimizi İnceleyin →
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Vision Section -->
<section class="section" style="padding-top: 40px;">
    <div class="section-container">
        <div class="about-content-grid" style="direction: rtl;">
            <div class="about-text animate-on-scroll" style="direction: ltr;">
                <h2>Vizyonumuz</h2>
                <p>
                    Eğitim teknolojilerinde global ölçekte rekabet edebilen, yapay zeka destekli akıllı
                    çözümler üreten ve eğitim ekosisteminin her paydaşına değer katan bir teknoloji şirketi
                    olmayı hedefliyoruz.
                </p>
                <p>
                    Araştırma ve geliştirme yatırımlarımız ile sürekli yenilenen ürün portföyümüz
                    sayesinde, müşterilerimize her zaman en güncel çözümleri sunuyoruz.
                </p>
            </div>
            <div class="about-image-wrapper animate-on-scroll" style="direction: ltr;">
                <div class="about-image-box">
                    <div class="placeholder-content">
                        <div class="placeholder-icon">🌐</div>
                        <div class="placeholder-text">Global Vizyon & Büyüme</div>
                    </div>
                </div>
                <div class="about-image-decor" style="left:-40px; right: auto;"></div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="section">
    <div class="section-container">
        <div class="section-header animate-on-scroll">
            <span class="section-badge">💎 Değerlerimiz</span>
            <h2 class="section-title">Bizi Biz Yapan Değerler</h2>
            <p class="section-description">
                Her adımımızda bizlere rehberlik eden temel ilke ve değerlerimiz.
            </p>
        </div>

        <div class="values-grid">
            <div class="value-card animate-on-scroll delay-1">
                <div class="value-icon">🎯</div>
                <h3>Müşteri Odaklılık</h3>
                <p>Müşterilerimizin ihtiyaçlarını anlamak ve en iyi çözümleri sunmak önceliğimizdir.</p>
            </div>
            <div class="value-card animate-on-scroll delay-2">
                <div class="value-icon">💡</div>
                <h3>Yenilikçilik</h3>
                <p>Sürekli araştırma ve geliştirme ile teknolojinin sınırlarını zorluyoruz.</p>
            </div>
            <div class="value-card animate-on-scroll delay-3">
                <div class="value-icon">🤝</div>
                <h3>Güvenilirlik</h3>
                <p>Şeffaf iletişim ve tutarlı performans ile müşterilerimizin güvenini kazanıyoruz.</p>
            </div>
            <div class="value-card animate-on-scroll delay-4">
                <div class="value-icon">⚡</div>
                <h3>Mükemmellik</h3>
                <p>Her projede en yüksek kalite standartlarını hedefleyerek fark yaratıyoruz.</p>
            </div>
        </div>
    </div>
</section>

<!-- Team Section -->
<section class="section">
    <div class="section-container">
        <div class="section-header animate-on-scroll">
            <span class="section-badge">👥 Ekibimiz</span>
            <h2 class="section-title">Uzman Kadromuz</h2>
            <p class="section-description">
                Alanında uzman, tutkulu ve deneyimli ekip üyelerimiz.
            </p>
        </div>

        <div class="team-grid">
            <div class="team-card animate-on-scroll delay-1">
                <div class="team-avatar">👨‍💼</div>
                <div class="team-info">
                    <h3>Ahmet Yılmaz</h3>
                    <p>CEO & Kurucu</p>
                </div>
            </div>
            <div class="team-card animate-on-scroll delay-2">
                <div class="team-avatar">👩‍💻</div>
                <div class="team-info">
                    <h3>Elif Kaya</h3>
                    <p>CTO</p>
                </div>
            </div>
            <div class="team-card animate-on-scroll delay-3">
                <div class="team-avatar">👨‍🔬</div>
                <div class="team-info">
                    <h3>Mehmet Demir</h3>
                    <p>Ürün Müdürü</p>
                </div>
            </div>
            <div class="team-card animate-on-scroll delay-4">
                <div class="team-avatar">👩‍🎨</div>
                <div class="team-info">
                    <h3>Ayşe Çelik</h3>
                    <p>Tasarım Direktörü</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section cta-section">
    <div class="section-container">
        <div class="cta-content animate-on-scroll">
            <h2>Birlikte <span class="gradient-text">Büyüyelim</span></h2>
            <p>Ekibimize katılın veya projeleriniz için bizimle iletişime geçin.</p>
            <div class="cta-buttons">
                <a asp-controller="Home" asp-action="Contact" class="btn-primary-custom">
                    İletişime Geç →
                </a>
            </div>
        </div>
    </div>
</section>
