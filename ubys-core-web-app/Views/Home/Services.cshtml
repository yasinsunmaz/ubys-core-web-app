@{
    ViewData["Title"] = "Hizmetlerimiz";
}

<!-- Page Header -->
<section class="page-header">
    <div class="page-header-bg">
        <div class="header-orb header-orb-1"></div>
        <div class="header-orb header-orb-2"></div>
    </div>
    <div class="section-container page-header-content">
        <span class="section-badge animate-on-scroll">🛠️ Hizmetlerimiz</span>
        <h1 class="section-title animate-on-scroll" style="font-size: clamp(2.5rem, 5vw, 3.5rem);">
            Kapsamlı <span class="gradient-text">Eğitim Çözümleri</span>
        </h1>
        <p class="section-description animate-on-scroll">
            Üniversitelerin tüm ihtiyaçlarına yönelik entegre ve modern çözümler sunuyoruz.
        </p>
    </div>
</section>

<!-- Services Detail -->
<section class="section" style="padding-top: 40px;">
    <div class="section-container">
        <div class="services-detail-grid">
            <div class="service-detail-card animate-on-scroll delay-1">
                <span class="service-number">01</span>
                <div class="service-icon-lg" style="background: rgba(108,92,231,0.12); color: var(--primary-light);">🎓</div>
                <h3>Öğrenci Bilgi Sistemi</h3>
                <p>Öğrenci kayıt, takip ve yönetim süreçlerinin tamamını dijitalleştirin. Kişiselleştirilmiş öğrenci deneyimi sunun.</p>
                <ul class="service-features-list">
                    <li>Online kayıt ve kabul süreçleri</li>
                    <li>Akademik performans takibi</li>
                    <li>Dijital transkript ve belge yönetimi</li>
                    <li>Mobil öğrenci uygulaması</li>
                </ul>
            </div>
            <div class="service-detail-card animate-on-scroll delay-2">
                <span class="service-number">02</span>
                <div class="service-icon-lg" style="background: rgba(0,206,201,0.12); color: var(--accent);">📚</div>
                <h3>Ders & Müfredat Yönetimi</h3>
                <p>Müfredat planlaması, ders programı oluşturma ve akademik takvim yönetimini kolaylaştırın.</p>
                <ul class="service-features-list">
                    <li>Otomatik ders programı oluşturma</li>
                    <li>Müfredat versiyon kontrolü</li>
                    <li>Ön koşul ve kredi yönetimi</li>
                    <li>Akademik takvim planlama</li>
                </ul>
            </div>
            <div class="service-detail-card animate-on-scroll delay-1">
                <span class="service-number">03</span>
                <div class="service-icon-lg" style="background: rgba(253,121,168,0.12); color: var(--warm);">📝</div>
                <h3>Sınav & Değerlendirme</h3>
                <p>Online sınav platformu, otomatik değerlendirme ve analitik raporlama ile sınav süreçlerini optimize edin.</p>
                <ul class="service-features-list">
                    <li>Online sınav platformu</li>
                    <li>Otomatik not hesaplama (BAP, GPA)</li>
                    <li>Soru bankası yönetimi</li>
                    <li>Kopya önleme teknolojileri</li>
                </ul>
            </div>
            <div class="service-detail-card animate-on-scroll delay-2">
                <span class="service-number">04</span>
                <div class="service-icon-lg" style="background: rgba(253,203,110,0.12); color: var(--warm-light);">📊</div>
                <h3>Analitik & Raporlama</h3>
                <p>Veri odaklı karar almayı destekleyen gelişmiş raporlama ve dashboard araçları ile kurumsal performansı ölçün.</p>
                <ul class="service-features-list">
                    <li>Gerçek zamanlı dashboard</li>
                    <li>Özelleştirilebilir raporlar</li>
                    <li>Tahmine dayalı analitik (AI)</li>
                    <li>YÖK istatistik entegrasyonu</li>
                </ul>
            </div>
            <div class="service-detail-card animate-on-scroll delay-1">
                <span class="service-number">05</span>
                <div class="service-icon-lg" style="background: rgba(85,239,196,0.12); color: var(--accent-light);">💰</div>
                <h3>Mali İşler & Burs Yönetimi</h3>
                <p>Harç takibi, burs yönetimi ve mali raporlama süreçlerini tek bir platform üzerinden yönetin.</p>
                <ul class="service-features-list">
                    <li>Online harç ödeme sistemi</li>
                    <li>Burs başvuru ve değerlendirme</li>
                    <li>Bütçe planlama araçları</li>
                    <li>Mali raporlama ve denetim</li>
                </ul>
            </div>
            <div class="service-detail-card animate-on-scroll delay-2">
                <span class="service-number">06</span>
                <div class="service-icon-lg" style="background: rgba(116,185,255,0.12); color: #74b9ff;">🔗</div>
                <h3>Entegrasyon & API</h3>
                <p>YÖKSİS, e-Devlet, KYK ve diğer kurumsal sistemler ile sorunsuz entegrasyon sağlayın.</p>
                <ul class="service-features-list">
                    <li>YÖKSİS entegrasyonu</li>
                    <li>e-Devlet bağlantısı</li>
                    <li>RESTful API altyapısı</li>
                    <li>Özel entegrasyon çözümleri</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<!-- Process Section -->
<section class="section">
    <div class="section-container">
        <div class="section-header animate-on-scroll">
            <span class="section-badge">📋 Süreç</span>
            <h2 class="section-title">Nasıl Çalışırız?</h2>
            <p class="section-description">
                Size özel çözüm sürecimiz 4 basit adımdan oluşur.
            </p>
        </div>

        <div class="process-grid">
            <div class="process-card animate-on-scroll delay-1">
                <div class="process-number">1</div>
                <h3>Analiz</h3>
                <p>Kurumunuzun ihtiyaçlarını detaylı analiz eder, mevcut süreçleri değerlendiririz.</p>
            </div>
            <div class="process-card animate-on-scroll delay-2">
                <div class="process-number">2</div>
                <h3>Planlama</h3>
                <p>Size özel çözüm planı oluşturur, proje takvimini belirleriz.</p>
            </div>
            <div class="process-card animate-on-scroll delay-3">
                <div class="process-number">3</div>
                <h3>Uygulama</h3>
                <p>Sistemi kurar, veri aktarımını yapar ve kullanıcı eğitimlerini düzenleriz.</p>
            </div>
            <div class="process-card animate-on-scroll delay-4">
                <div class="process-number">4</div>
                <h3>Destek</h3>
                <p>7/24 teknik destek ve sürekli güncelleme ile yanınızda olmaya devam ederiz.</p>
            </div>
        </div>
    </div>
</section>

<!-- Pricing Section -->
<section class="section">
    <div class="section-container">
        <div class="section-header animate-on-scroll">
            <span class="section-badge">💎 Paketler</span>
            <h2 class="section-title">Size Uygun Plan</h2>
            <p class="section-description">
                Kurumunuzun büyüklüğüne ve ihtiyaçlarına göre esnek paketler sunuyoruz.
            </p>
        </div>

        <div class="pricing-grid">
            <div class="pricing-card animate-on-scroll delay-1">
                <h3>Başlangıç</h3>
                <p class="pricing-desc">Küçük ölçekli kurumlar için</p>
                <div class="pricing-price">
                    <span class="price-value">₺24.900</span>
                    <span class="price-period">/yıl</span>
                </div>
                <ul class="pricing-features">
                    <li><span class="check">✓</span> 5.000'e kadar öğrenci</li>
                    <li><span class="check">✓</span> Temel modüller</li>
                    <li><span class="check">✓</span> Email destek</li>
                    <li><span class="check">✓</span> Standart raporlama</li>
                    <li><span class="check">✓</span> Yıllık güncelleme</li>
                </ul>
                <a asp-controller="Home" asp-action="Contact" class="btn-outline-custom" style="width:100%;justify-content:center;">
                    İletişime Geç
                </a>
            </div>
            <div class="pricing-card featured animate-on-scroll delay-2">
                <h3>Profesyonel</h3>
                <p class="pricing-desc">Orta ölçekli üniversiteler için</p>
                <div class="pricing-price">
                    <span class="price-value">₺49.900</span>
                    <span class="price-period">/yıl</span>
                </div>
                <ul class="pricing-features">
                    <li><span class="check">✓</span> 25.000'e kadar öğrenci</li>
                    <li><span class="check">✓</span> Tüm modüller</li>
                    <li><span class="check">✓</span> 7/24 telefon destek</li>
                    <li><span class="check">✓</span> Gelişmiş analitik</li>
                    <li><span class="check">✓</span> API erişimi</li>
                </ul>
                <a asp-controller="Home" asp-action="Contact" class="btn-primary-custom" style="width:100%;justify-content:center;">
                    Hemen Başlayın →
                </a>
            </div>
            <div class="pricing-card animate-on-scroll delay-3">
                <h3>Kurumsal</h3>
                <p class="pricing-desc">Büyük üniversiteler için</p>
                <div class="pricing-price">
                    <span class="price-value">Özel</span>
                    <span class="price-period">teklif</span>
                </div>
                <ul class="pricing-features">
                    <li><span class="check">✓</span> Sınırsız öğrenci</li>
                    <li><span class="check">✓</span> Özel modül geliştirme</li>
                    <li><span class="check">✓</span> Özel hesap yöneticisi</li>
                    <li><span class="check">✓</span> Yerinde kurulum seçeneği</li>
                    <li><span class="check">✓</span> SLA garantisi</li>
                </ul>
                <a asp-controller="Home" asp-action="Contact" class="btn-outline-custom" style="width:100%;justify-content:center;">
                    Teklif Alın
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="section cta-section">
    <div class="section-container">
        <div class="cta-content animate-on-scroll">
            <h2>Projelerinizi <span class="gradient-text">Hayata Geçirelim</span></h2>
            <p>Kurumunuza özel demo planlayalım ve ihtiyaçlarınızı birlikte değerlendirelim.</p>
            <div class="cta-buttons">
                <a asp-controller="Home" asp-action="Contact" class="btn-primary-custom">
                    Demo Talep Et →
                </a>
            </div>
        </div>
    </div>
</section>
